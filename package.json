{
  "name": "the-quiet-page",
  "productName": "The Quiet Page",
  "version": "1.1.0",
  "description": "A private, offline desktop writing journal for Arabic and English.",
  "main": "src/main/main.js",
  "author": "The Quiet Page contributors",
  "license": "MIT",
  "homepage": "https://github.com/YARObHATEM/the-quiet-page#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YARObHATEM/the-quiet-page.git"
  },
  "bugs": {
    "url": "https://github.com/YARObHATEM/the-quiet-page/issues"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "check": "node scripts/check.js",
    "test": "npm run check",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis portable --x64 --publish never"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "electron": "42.4.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.thequietpage.app",
    "productName": "The Quiet Page",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "src/**/*",
      "licenses/**/*",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "The-Quiet-Page-${version}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "The Quiet Page",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "The-Quiet-Page-${version}-Portable.${ext}"
    }
  }
}
